---
const { title, desktop, mobile } = Astro.props;
---

<div class="relative group cursor-pointer overflow-hidden">

  
  <img
    src={mobile}
    alt={title}
    class="w-full h-[120px] object-cover md:hidden"
  />

 
  <img
    src={desktop}
    alt={title}
    class="w-full h-[450px] object-cover hidden md:block transition duration-300 group-hover:scale-105"
  />

  <div class="absolute inset-0 bg-black/30 group-hover:bg-white/70 transition"></div>

  <div class="absolute bottom-6 left-6 right-6">
    <h3 class="text-white text-2xl font-[Josefin_Sans] uppercase leading-tight max-w-[9ch] group-hover:text-black">
      {title}
    </h3>
  </div>

</div>